{
  "manifest_version": 3,
  "name": "SaveMyPrompt",
  "version": "1.0.0",
  "description": "Hover-to-save prompt library for ChatGPT & Claude — cleans prompts into reusable templates. No AI, no account, saves locally.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SaveMyPrompt library",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.mistral.ai/*",
    "https://grok.com/*",
    "https://x.com/i/grok*",
    "https://copilot.microsoft.com/*",
    "https://meta.ai/*",
    "https://www.meta.ai/*",
    "https://you.com/*",
    "https://t3.chat/*",
    "https://huggingface.co/chat/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://copilot.microsoft.com/*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://you.com/*",
        "https://t3.chat/*",
        "https://huggingface.co/chat/*"
      ],
      "js": ["lib/icons.js", "lib/clean.js", "lib/store.js", "lib/styles.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
